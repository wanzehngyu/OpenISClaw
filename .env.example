# OpenISClaw 环境变量配置
# 复制此文件为 .env 并填入真实值
#
#   cp .env.example .env
#   nano .env

# ── LLM API 配置 ──────────────────────────────────────────
# 必须设置（Agent Loop / API Server 模式需要）

# OpenAI API Key
OPENAI_API_KEY=sk-xxx

# 可选：自定义 API Base URL（如使用代理或兼容 API）
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：指定模型，默认 gpt-4o
# 支持：gpt-4o, gpt-4o-mini, gpt-4-turbo, claude-3-opus, claude-3-sonnet 等
# MODEL=gpt-4o

# ── 其他可选变量 ──────────────────────────────────────────

# API Server 端口（默认 8000）
# PORT=8000
